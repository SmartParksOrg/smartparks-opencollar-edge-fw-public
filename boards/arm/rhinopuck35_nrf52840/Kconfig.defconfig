if BOARD_RHINOPUCK35_NRF52840

config BOARD
	default "rhinopuck35_nrf52840"

if USB

config USB_NRFX
	default y

config USB_DEVICE_STACK
	default y

endif # USB

config IEEE802154_NRF5
	default y
	depends on IEEE802154

config BT_CTLR
	default BT

endif # BOARD_RHINOPUCK35_NRF52840
