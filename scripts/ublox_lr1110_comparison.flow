    {
        "id": "11f94b22.d07de5",
        "type": "function",
        "z": "277278ea.bf515",
        "name": "Prepare request",
        "func": "if(msg.port == 1)\n{\n\n    var URL = \"https://gls.loracloud.com/api/v3/solve/gnss_lr1110_singleframe\" \n    var AUTH_TOKEN = \"AQEAjN9V8sDHZRTuLMT7Q0SmXsS2LBIpdPzGH98zBlp68T89elcT\"\n    var LAT = msg.payload.latitude\n    var LON = msg.payload.longitude\n    var nav_payload = msg.payload.nav_payload\n    var gps_time = msg.payload.gps_time\n    \n    var json_dict = {\n        \"payload\": nav_payload,\n        \"gnss_capture_time\": gps_time,\n        \"gnss_capture_time_accuracy\": 17, \n        \"gnss_assist_position\" : [LAT, LON]\n    }\n    var headers = {\n        'Accept':'application/json',\n        'Ocp-Apim-Subscription-Key': AUTH_TOKEN\n    }\n    \n    msg = {\n        \"url\": URL,\n        \"headers\": headers,\n        \"payload\": json_dict\n    }\n    \n    return msg;\n}\n",
        "outputs": 1,
        "noerr": 0,
        "x": 460,
        "y": 840,
        "wires": [
            [
                "1987f67d.ed0f42"
            ]
        ]
    },
    {
        "id": "1987f67d.ed0f42",
        "type": "http request",
        "z": "277278ea.bf515",
        "name": "Lora Cloud GNSS",
        "method": "POST",
        "ret": "txt",
        "paytoqs": false,
        "url": "https://gls.loracloud.com/api/v3/solve/gnss_lr1110_singleframe",
        "tls": "",
        "proxy": "",
        "authType": "basic",
        "x": 670,
        "y": 840,
        "wires": [
            [
                "132d168c.449731",
                "369e923e.195cf6"
            ]
        ]
    },
    {
        "id": "132d168c.449731",
        "type": "function",
        "z": "277278ea.bf515",
        "name": "Parse response",
        "func": "var object = JSON.parse(msg.payload)\n\nmsg.payload = [{\n    lat:   object.result.llh[0],\n    lon:   object.result.llh[1],\n    gdop:   object.result.gdop,\n    accuracy:   object.result.accuracy,\n},\n{ \n    devId: \"nordic_test\"\n}]\nreturn msg;",
        "outputs": 1,
        "noerr": 0,
        "x": 880,
        "y": 840,
        "wires": [
            [
                "3fb6a1e2.d4f056"
            ]
        ]
    },
