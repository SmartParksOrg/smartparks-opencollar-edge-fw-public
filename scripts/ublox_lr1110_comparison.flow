        "name": "IrnasLacuna",
        "measurement": "lacuna_lib-test",
        "precision": "",
        "retentionPolicy": "",
        "x": 1110,
        "y": 860,
        "wires": []
    },
    {
        "id": "91c0c4ee.c23538",
        "type": "function",
        "z": "277278ea.bf515",
        "name": "Format ublox data",
        "func": "if(msg.port == 2)\n{\n    if(msg.payload.latitude !== 0 || msg.payload.longitude !== 0 || msg.payload.altitude !== 0)\n    {\n        msg.payload = [{\n            ublox_lat:        msg.payload.latitude,\n            ublox_lon:        msg.payload.longitude,\n            ublox_alt:        msg.payload.altitude,\n        },\n        { \n            devId: msg.dev_id\n        }]\n    \n        return msg;\n    }\n}\n",
        "outputs": 1,
        "noerr": 0,
        "x": 470,
        "y": 880,
        "wires": [
